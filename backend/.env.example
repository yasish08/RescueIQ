# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# PostgreSQL (Supabase or any Postgres instance)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# App settings
SURPLUS_THRESHOLD=10
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://10.0.2.2:5173

# Background scheduler
ENABLE_BACKGROUND_SCHEDULER=true
SCHEDULER_TIMEZONE=Asia/Kolkata
DAILY_PREDICT_HOUR=8
DAILY_PREDICT_MINUTE=0
DAILY_PREDICT_EVENT_FLAG=0
DAILY_PREDICT_WEATHER_SCORE=0.5
WEEKLY_RETRAIN_DAY=sun
WEEKLY_RETRAIN_HOUR=2
WEEKLY_RETRAIN_MINUTE=0
